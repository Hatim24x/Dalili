{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "A business registered on the platform",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "isOpen": { "type": "boolean" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "viewsCount": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "businessHours": {
          "type": "object",
          "properties": {
            "open": { "type": "string" },
            "close": { "type": "string" }
          }
        }
      },
      "required": ["ownerId", "name", "category", "location"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "shopId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["shopId", "userId", "rating"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "owner", "admin"] },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "shopId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "shopId"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text"]
    }
  },
  "firestore": {
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Collection of all shops"
    },
    "/shops/{shopId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific shop"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profile data"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "List of active chats"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific chat"
    }
  }
}
